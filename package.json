{
  "name": "slaply-phase1",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "generate:ai-prompts": "node scripts/generate-ai-prompts.mjs",
    "prebuild": "npm run generate:ai-prompts",
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "node scripts/build-cloudflare-sanitized.mjs",
    "build:cloudflare:direct": "opennextjs-cloudflare build",
    "preview:cloudflare": "npm run build:cloudflare && opennextjs-cloudflare preview",
    "deploy:cloudflare": "npm run build:cloudflare && opennextjs-cloudflare deploy --env=\"\"",
    "deploy:cloudflare:production": "npm run build:cloudflare && opennextjs-cloudflare deploy --env production",
    "start": "next start"
  },
  "dependencies": {
    "next": "latest",
    "openai": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.8",
    "wrangler": "^4.90.0"
  },
  "engines": {
    "node": ">=20"
  }
}
