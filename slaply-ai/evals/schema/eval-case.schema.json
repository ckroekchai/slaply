{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slaply.co/schemas/eval-case.schema.json",
  "title": "Slaply Prompt Eval Case Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "tier",
    "active",
    "category",
    "language",
    "artwork_ref",
    "artwork_storage",
    "storage_owner",
    "source_project_ref",
    "expected_focus",
    "known_issues",
    "must_not_flag",
    "privacy_status"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$",
      "description": "Stable case ID, for example SKINCARE_001."
    },
    "tier": {
      "type": "string",
      "enum": ["golden", "regression", "case_bank"]
    },
    "active": {
      "type": "boolean",
      "description": "Whether this case is currently part of its assigned eval tier."
    },
    "category": {
      "type": "string",
      "enum": ["Beauty / Skincare", "Supplement", "Food / Snack", "Ads / Promotion"]
    },
    "language": {
      "type": "string",
      "enum": ["Thai", "English"]
    },
    "artwork_ref": {
      "type": "string",
      "description": "Private/local placeholder reference only. Do not use public URLs or commit artwork files."
    },
    "artwork_storage": {
      "type": "string",
      "enum": ["local_private", "icloud_private", "r2_private", "external_private", "synthetic_placeholder"],
      "description": "Where the real artwork is stored outside the repo."
    },
    "storage_owner": {
      "type": "string",
      "description": "Person or private storage owner responsible for the source artwork."
    },
    "source_project_ref": {
      "type": "string",
      "description": "Optional internal/private project reference, not a customer name."
    },
    "expected_focus": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["Text Errors", "Hierarchy", "Readability"]
      }
    },
    "known_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["issue_type", "expected_behavior"],
        "properties": {
          "issue_type": {
            "type": "string",
            "enum": ["Text Errors", "Hierarchy", "Readability"]
          },
          "anchor": {
            "type": "string",
            "description": "Sanitized visible text or artwork element the expected issue is anchored to."
          },
          "location_hint": {
            "type": "string",
            "description": "Approximate location, for example front upper-right. Do not include customer-sensitive content."
          },
          "expected_behavior": {
            "type": "string",
            "description": "What a good report should flag or avoid."
          },
          "severity_hint": {
            "type": "string",
            "enum": ["High", "Medium", "Low", "None"]
          }
        }
      },
      "description": "Human-known concrete visible issues. Keep sanitized and avoid customer-sensitive text unless necessary."
    },
    "must_not_flag": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "broad_design_critique",
          "premium_judgment",
          "beauty_taste_comment",
          "art_direction_judgment",
          "compliance_approval",
          "fda_thai_fda_regulatory_approval",
          "print_ready_certification",
          "manufacturing_approval",
          "sales_guarantee"
        ]
      },
      "description": "Things the AI must not flag, such as broad design critique, premium judgment, compliance approval, print-ready certification, or sales guarantees."
    },
    "failure_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "false_positive",
          "missed_issue",
          "bad_severity",
          "bad_annotation",
          "scope_creep",
          "overclaim",
          "bad_tone",
          "language_mismatch",
          "weak_recommendation",
          "json_contract_risk"
        ]
      }
    },
    "sampling_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags used to sample a balanced Golden or Regression Set from the private case bank."
    },
    "last_reviewed_prompt_version": {
      "type": "string"
    },
    "review_status": {
      "type": "string",
      "enum": ["candidate", "active", "paused", "retired"]
    },
    "edge_case_notes": {
      "type": "string"
    },
    "privacy_status": {
      "type": "string",
      "enum": ["private_artwork_not_committed", "synthetic_placeholder"]
    },
    "last_reviewed_at": {
      "type": "string",
      "format": "date"
    }
  }
}
